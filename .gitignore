# =============================================================
# CropGuard Ghana — .gitignore
# Covers: Python, Flask, Node, Docker, Terraform, IDEs, OS
# =============================================================

# ── Secrets & Environment ─────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets/
config.local.yml
config.local.yaml
*.secret
credentials.json

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.Python

# Virtual Environments
venv/
env/
ENV/
.venv/
virtualenv/

# Testing & Coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
nosetests.xml
test-results/
junit.xml

# Type checking
.mypy_cache/
.dmypy.json
.pytype/

# ── Node / JS ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
package-lock.json
.next/
.nuxt/
.cache/

# ── Database ─────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
instance/
migrations/versions/*.pyc

# ── Docker ───────────────────────────────────────────────────
docker-compose.override.yml

# ── Terraform ────────────────────────────────────────────────
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
*.tfvars
!example.tfvars
crash.log

# ── Build & Logs ─────────────────────────────────────────────
*.log
logs/
*.out
*.pid
pids/
*.gz
*.tar
*.zip

# ── IDEs ─────────────────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ── OS ────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ── Misc ──────────────────────────────────────────────────────
.hypothesis/
*.bak
*.tmp
*.orig
staticfiles/
media/
uploads/
terraform/terraform.tfvars
terraform/.terraform/
bastion_key
bastion_key.pub
bastion_key
bastion_key.pub
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/terraform.tfvars
